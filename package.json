{
    "name": "vrc-item-bot-booth",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "postinstall": "nitro prepare",
        "build": "bun run --bun nitro build",
        "dev": "bun run --bun nitro dev",
        "preview": "bun run --bun nitro preview",
        "start": "bun run ./.output/server/index.mjs",
        "test": "bun test",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "cheerio": "^1.2.0",
        "discord.js": "14.26.4",
        "nitro": "3.0.260603-beta",
        "railway": "^3.1.1"
    },
    "devDependencies": {
        "@types/bun": "1.3.14",
        "consola": "3.4.2",
        "oxfmt": "^0.53.0",
        "oxlint": "^1.68.0",
        "oxlint-tsgolint": "^0.23.0",
        "taze": "^19.14.1",
        "typescript": "6.0.3"
    },
    "engines": {
        "bun": "1.x"
    }
}
